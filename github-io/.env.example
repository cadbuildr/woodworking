VITE_APP_BASE_PATH=/
# Optional: local kernel-api (default PORT 8087).
# VITE_KERNEL_API_BASE_URL=http://127.0.0.1:8087
# Optional overrides — by default BOTH wheels load from same-origin local-wheels/
# (dev serves them from the packages' dist/ via Vite middleware; prod: run sync-wheels).
# VITE_FOUNDATION_WHEEL_URL=
# VITE_WOODWORKING_WHEEL_URL=
# Viewer auth (one of the two): publishable partner keyId (browser flow, safe
# to expose — origin-checked) or a server-minted session token.
# VITE_CADBUILDR_KEY_ID=
# VITE_CADBUILDR_SESSION_TOKEN=
